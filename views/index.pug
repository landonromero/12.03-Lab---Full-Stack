extends layout

block content
  .container
    h1= title
    p.subtitle Manage tasks quickly with editing, completion toggles, and validation.

    if message
      .message= message

    ol.task-list
      each val in todos
        li.todo-item(class= val.completed > 0 ? 'completed' : 'pending')
          if editTodo && editTodo.id == val.id
            form.edit-form(method='POST' action='/update')
              input(type='hidden', name='id', value=val.id)
              label(for='task-' + val.id) Description
              input(type='text', id='task-' + val.id, name='task', required, value=val.task)
              label.checkbox-label
                input(type='checkbox', name='completed', checked=val.completed > 0)
                | Completed
              .action-row
                button(type='submit') Save Changes
                a.button.secondary(href='/') Cancel
          else
            .task-row
              .task-details
                span.task-text= val.task
                span.status-label= val.completed > 0 ? 'Completed' : 'Not Completed'
              .button-group
                form.inline(method='POST' action='/toggle')
                  input(type='hidden', name='id', value=val.id)
                  button(type='submit')= val.completed > 0 ? 'Mark Not Completed' : 'Mark Completed'
                a.button(href='/edit/' + val.id) Edit
                form.inline(method='POST' action='/delete')
                  input(type='hidden', name='id', value=val.id)
                  button(type='submit') Delete

    hr

    h2 Add a new task
    form.add-form(method='POST' action='/create')
      label(for='task') Task:
      input(type='text', name='task', id='task', required)
      button(type='submit') Create Task
